#!/bin/bash
# =============================================================================
# taco - Taco Obs Server Health Check Agent
# https://github.com/tacoobs/agent
#
# Coleta metricas do servidor e envia para webhook.
# Detecta automaticamente o ambiente (Docker, PostgreSQL, Redis, Nginx, etc).
#
# Uso:
#   taco install     Wizard interativo de configuracao
#   taco config      Editar configuracao (valor individual ou wizard)
#   taco run         Executa health check e envia report
#   taco test        Envia report de teste para validar webhook
#   taco status      Mostra configuracao atual e agendamento
#   taco logs        Mostra ultimos logs de execucao
#   taco uninstall   Remove configuracao, timer e logs
#   taco help        Mostra esta ajuda
# =============================================================================

set -uo pipefail

VERSION="1.0.0"
CONFIG_DIR="/etc/taco"
CONFIG_FILE="$CONFIG_DIR/taco.conf"
LOG_DIR="/var/log/taco"
LOG_FILE="$LOG_DIR/taco.log"
SYSTEMD_SERVICE="/etc/systemd/system/taco.service"
SYSTEMD_TIMER="/etc/systemd/system/taco.timer"

# -- Cores --------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# -- Helpers ------------------------------------------------------------------
info()  { echo -e "${BLUE}[taco]${NC} $1"; }
ok()    { echo -e "${GREEN}[taco]${NC} $1"; }
warn()  { echo -e "${YELLOW}[taco]${NC} $1"; }
err()   { echo -e "${RED}[taco]${NC} $1"; }
bold()  { echo -e "${BOLD}$1${NC}"; }

need_root() {
  if [ "$(id -u)" -ne 0 ]; then
    err "Este comando precisa de sudo: ${BOLD}sudo taco $1${NC}"
    exit 1
  fi
}

load_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    err "Taco nao configurado. Execute: ${BOLD}sudo taco install${NC}"
    exit 1
  fi
  source "$CONFIG_FILE"
}

log_write() {
  mkdir -p "$LOG_DIR"
  echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $1" >> "$LOG_FILE"
}

ask() {
  local prompt="$1" default="$2" var="$3"
  if [ -n "$default" ]; then
    echo -ne "  ${CYAN}${prompt}${NC} ${DIM}[${default}]${NC}: "
  else
    echo -ne "  ${CYAN}${prompt}${NC}: "
  fi
  read -r input
  eval "$var='${input:-$default}'"
}

ask_threshold() {
  local prompt="$1" default="$2" var="$3"
  echo -ne "    ${prompt} ${DIM}[${default}]${NC}: "
  read -r input
  eval "$var='${input:-$default}'"
}

# =============================================================================
# INSTALL
# =============================================================================
cmd_install() {
  need_root "install"

  echo ""
  bold "  =================================="
  bold "    taco install - Taco Obs v${VERSION}"
  bold "  =================================="
  echo ""

  # Detectar defaults
  local default_name default_ip
  default_name=$(hostname)
  default_ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "")

  # Deteccao de ambiente
  echo -e "  ${DIM}Detectando ambiente...${NC}"
  local caps=""
  command -v docker &>/dev/null && docker info &>/dev/null 2>&1 && caps="${caps} docker"
  command -v nginx &>/dev/null && caps="${caps} nginx"
  command -v psql &>/dev/null && caps="${caps} postgresql"
  command -v redis-cli &>/dev/null && caps="${caps} redis"
  command -v certbot &>/dev/null && caps="${caps} certbot"
  command -v systemctl &>/dev/null && caps="${caps} systemd"

  if [ -n "$(docker ps --format '{{.Names}}' 2>/dev/null | grep -i postgres || true)" ]; then
    caps="${caps} postgresql"
  fi
  if [ -n "$(docker ps --format '{{.Names}}' 2>/dev/null | grep -i redis || true)" ]; then
    caps="${caps} redis"
  fi

  caps=$(echo "$caps" | tr ' ' '\n' | sort -u | tr '\n' ' ' | xargs)
  echo -e "  ${GREEN}Detectado:${NC} ${caps:-nenhum servico especifico}"
  echo ""

  # Servidor
  bold "  -- Servidor --"
  ask "Nome do servidor" "$default_name" "SERVER_NAME"
  ask "IP do servidor" "$default_ip" "SERVER_IP"
  echo ""

  # Webhook
  bold "  -- Webhook --"
  ask "URL do webhook (N8N, Zapier, etc)" "" "WEBHOOK_URL"
  while [ -z "$WEBHOOK_URL" ]; do
    warn "  Webhook URL e obrigatorio."
    ask "URL do webhook" "" "WEBHOOK_URL"
  done
  echo ""

  # Thresholds
  bold "  -- Thresholds de alerta --"
  echo -e "  ${DIM}(pressione Enter para manter o padrao)${NC}"
  echo ""
  echo -e "  ${BOLD}Disco:${NC}"
  ask_threshold "Warning %" "70" "DISK_WARN"
  ask_threshold "Critical %" "85" "DISK_CRIT"
  echo -e "  ${BOLD}Memoria:${NC}"
  ask_threshold "Warning %" "80" "MEM_WARN"
  ask_threshold "Critical %" "95" "MEM_CRIT"
  echo -e "  ${BOLD}Load average (multiplicador de CPUs):${NC}"
  ask_threshold "Warning" "2" "LOAD_FACTOR_WARN"
  ask_threshold "Critical" "4" "LOAD_FACTOR_CRIT"

  if echo "$caps" | grep -q "redis"; then
    echo -e "  ${BOLD}Filas Sidekiq:${NC}"
    ask_threshold "Warning (jobs)" "50" "QUEUE_WARN"
    ask_threshold "Critical (jobs)" "200" "QUEUE_CRIT"
  else
    QUEUE_WARN=50
    QUEUE_CRIT=200
  fi

  if echo "$caps" | grep -q "postgresql"; then
    echo -e "  ${BOLD}PostgreSQL dead tuples:${NC}"
    ask_threshold "Warning" "30000" "DEAD_TUPLES_WARN"
    ask_threshold "Critical" "80000" "DEAD_TUPLES_CRIT"
  else
    DEAD_TUPLES_WARN=30000
    DEAD_TUPLES_CRIT=80000
  fi

  echo -e "  ${BOLD}Docker logs:${NC}"
  ask_threshold "Warning (GB)" "5" "LOG_SIZE_WARN_GB"
  echo ""

  # Banco PostgreSQL
  PG_DATABASE=""
  if echo "$caps" | grep -q "postgresql"; then
    bold "  -- PostgreSQL --"
    local detected_db=""
    local pg_container
    pg_container=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -i postgres | head -1 || true)
    if [ -n "$pg_container" ]; then
      detected_db=$(docker exec "$pg_container" psql -U postgres -t -A -c "SELECT datname FROM pg_database WHERE datname NOT IN ('postgres','template0','template1') ORDER BY pg_database_size(datname) DESC LIMIT 1;" 2>/dev/null || true)
    elif command -v psql &>/dev/null; then
      detected_db=$(psql -U postgres -t -A -c "SELECT datname FROM pg_database WHERE datname NOT IN ('postgres','template0','template1') ORDER BY pg_database_size(datname) DESC LIMIT 1;" 2>/dev/null || true)
    fi
    ask "Banco de dados" "$detected_db" "PG_DATABASE"
    echo ""
  fi

  # Agendamento
  bold "  -- Agendamento --"
  ask "Intervalo em minutos" "30" "INTERVAL_MIN"
  echo ""

  # Salvar config
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
# taco - Configuracao gerada em $(date)
SERVER_NAME="$SERVER_NAME"
SERVER_IP="$SERVER_IP"
WEBHOOK_URL="$WEBHOOK_URL"
DISK_WARN=$DISK_WARN
DISK_CRIT=$DISK_CRIT
MEM_WARN=$MEM_WARN
MEM_CRIT=$MEM_CRIT
LOAD_FACTOR_WARN=$LOAD_FACTOR_WARN
LOAD_FACTOR_CRIT=$LOAD_FACTOR_CRIT
QUEUE_WARN=$QUEUE_WARN
QUEUE_CRIT=$QUEUE_CRIT
DEAD_TUPLES_WARN=$DEAD_TUPLES_WARN
DEAD_TUPLES_CRIT=$DEAD_TUPLES_CRIT
LOG_SIZE_WARN_GB=$LOG_SIZE_WARN_GB
PG_DATABASE="$PG_DATABASE"
INTERVAL_MIN=$INTERVAL_MIN
EOF
  chmod 600 "$CONFIG_FILE"

  # Criar log dir
  mkdir -p "$LOG_DIR"

  # Criar systemd service + timer
  cat > "$SYSTEMD_SERVICE" <<EOF
[Unit]
Description=Taco Obs - Server Health Check
After=network.target docker.service

[Service]
Type=oneshot
ExecStart=$(readlink -f "$0") run
StandardOutput=journal
StandardError=journal
EOF

  cat > "$SYSTEMD_TIMER" <<EOF
[Unit]
Description=Taco Obs - Timer (every ${INTERVAL_MIN}min)

[Timer]
OnBootSec=2min
OnUnitActiveSec=${INTERVAL_MIN}min
AccuracySec=30s

[Install]
WantedBy=timers.target
EOF

  systemctl daemon-reload
  systemctl enable --now taco.timer 2>/dev/null

  echo -e "  ${DIM}──────────────────────────────────${NC}"
  ok "Config salva em ${BOLD}${CONFIG_FILE}${NC}"
  ok "Timer ativado: a cada ${BOLD}${INTERVAL_MIN} minutos${NC}"
  echo ""

  # Teste
  echo -ne "  ${CYAN}Enviar report de teste agora? [S/n]${NC}: "
  read -r do_test
  if [ "${do_test,,}" != "n" ]; then
    echo ""
    cmd_test
  fi

  echo ""
  ok "Instalacao completa!"
  echo -e "  ${DIM}Comandos: taco run | taco status | taco logs | taco test${NC}"
  echo ""
}

# =============================================================================
# CONFIG
# =============================================================================
cmd_config() {
  need_root "config"
  load_config

  local key="${2:-}"

  # taco config set <chave> <valor>
  if [ "$key" = "set" ]; then
    local param="${3:-}" value="${4:-}"
    if [ -z "$param" ] || [ -z "$value" ]; then
      err "Uso: ${BOLD}sudo taco config set <chave> <valor>${NC}"
      echo ""
      echo "  Chaves disponiveis:"
      grep -v '^#' "$CONFIG_FILE" | grep '=' | while IFS='=' read -r k v; do
        echo -e "    ${BOLD}${k}${NC}=${v}"
      done
      echo ""
      return 1
    fi

    param=$(echo "$param" | tr '[:lower:]' '[:upper:]')
    if ! grep -q "^${param}=" "$CONFIG_FILE"; then
      err "Chave '${param}' nao encontrada."
      return 1
    fi

    local old_value
    old_value=$(grep "^${param}=" "$CONFIG_FILE" | head -1 | cut -d'=' -f2-)

    # Detectar se o valor precisa de aspas
    if echo "$old_value" | grep -q '^"'; then
      sed -i "s|^${param}=.*|${param}=\"${value}\"|" "$CONFIG_FILE"
    else
      sed -i "s|^${param}=.*|${param}=${value}|" "$CONFIG_FILE"
    fi

    ok "${param}: ${old_value} -> ${BOLD}${value}${NC}"

    # Atualizar timer se mudou o intervalo
    if [ "$param" = "INTERVAL_MIN" ] && [ -f "$SYSTEMD_TIMER" ]; then
      sed -i "s|OnUnitActiveSec=.*|OnUnitActiveSec=${value}min|" "$SYSTEMD_TIMER"
      sed -i "s|Description=.*|Description=Taco Obs - Timer (every ${value}min)|" "$SYSTEMD_TIMER"
      systemctl daemon-reload
      systemctl restart taco.timer 2>/dev/null
      ok "Timer atualizado para ${BOLD}${value} minutos${NC}"
    fi
    return
  fi

  # taco config (interativo)
  echo ""
  bold "  taco config - Taco Obs v${VERSION}"
  echo -e "  ${DIM}──────────────────────────────────${NC}"
  echo ""
  echo "  Configuracao atual:"
  echo ""

  local i=1
  local keys=() values=()
  while IFS='=' read -r k v; do
    keys+=("$k")
    values+=("$v")
    echo -e "    ${BOLD}${i})${NC} ${k} = ${v}"
    i=$((i + 1))
  done < <(grep -v '^#' "$CONFIG_FILE" | grep '=')

  echo ""
  echo -e "    ${BOLD}w)${NC} Reabrir wizard completo"
  echo -e "    ${BOLD}q)${NC} Sair"
  echo ""

  echo -ne "  ${CYAN}Opcao${NC}: "
  read -r choice

  if [ "${choice,,}" = "q" ]; then
    return
  fi

  if [ "${choice,,}" = "w" ]; then
    cmd_install
    return
  fi

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#keys[@]} ]; then
    err "Opcao invalida."
    return 1
  fi

  local idx=$((choice - 1))
  local sel_key="${keys[$idx]}"
  local sel_val="${values[$idx]}"

  ask "Novo valor para ${sel_key}" "$sel_val" "new_val"

  if [ "$new_val" = "$sel_val" ]; then
    info "Nenhuma alteracao."
    return
  fi

  # Atualizar no arquivo
  if echo "$sel_val" | grep -q '^"'; then
    sed -i "s|^${sel_key}=.*|${sel_key}=\"${new_val}\"|" "$CONFIG_FILE"
  else
    sed -i "s|^${sel_key}=.*|${sel_key}=${new_val}|" "$CONFIG_FILE"
  fi

  ok "${sel_key}: ${sel_val} -> ${BOLD}${new_val}${NC}"

  if [ "$sel_key" = "INTERVAL_MIN" ] && [ -f "$SYSTEMD_TIMER" ]; then
    sed -i "s|OnUnitActiveSec=.*|OnUnitActiveSec=${new_val}min|" "$SYSTEMD_TIMER"
    sed -i "s|Description=.*|Description=Taco Obs - Timer (every ${new_val}min)|" "$SYSTEMD_TIMER"
    systemctl daemon-reload
    systemctl restart taco.timer 2>/dev/null
    ok "Timer atualizado para ${BOLD}${new_val} minutos${NC}"
  fi
  echo ""
}

# =============================================================================
# HEALTH CHECK (coleta + envio)
# =============================================================================
collect_and_send() {
  local mode="${1:-report}"  # report ou test

  load_config

  local timestamp overall_status alerts
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  overall_status="ok"
  alerts="[]"

  set_status_inner() {
    local level="$1"
    if [ "$level" = "critical" ]; then
      overall_status="critical"
    elif [ "$level" = "warning" ] && [ "$overall_status" != "critical" ]; then
      overall_status="warning"
    fi
  }

  classify_inner() {
    local value="$1" warn_val="$2" crit_val="$3"
    if [ "$value" -ge "$crit_val" ] 2>/dev/null; then
      echo "critical"
    elif [ "$value" -ge "$warn_val" ] 2>/dev/null; then
      echo "warning"
    else
      echo "ok"
    fi
  }

  add_alert_inner() {
    local level="$1" component="$2" message="$3"
    alerts=$(python3 -c "
import json
a = json.loads('''$alerts''')
a.append({'level': '$level', 'component': '$component', 'message': '''$message'''})
print(json.dumps(a))
")
    set_status_inner "$level"
  }

  # -- DISCO ------------------------------------------------------------------
  local disk_json root_pct disk_status
  disk_json=$(df -h --output=target,size,used,avail,pcent -x tmpfs -x devtmpfs -x squashfs 2>/dev/null | tail -n +2 | python3 -c "
import sys, json
parts = []
for line in sys.stdin:
    cols = line.split()
    if len(cols) == 5:
        parts.append({
            'mount': cols[0], 'size': cols[1], 'used': cols[2],
            'available': cols[3], 'usage_pct': int(cols[4].replace('%',''))
        })
print(json.dumps(parts))
")
  root_pct=$(df / --output=pcent | tail -1 | tr -dc '0-9')
  disk_status=$(classify_inner "$root_pct" "$DISK_WARN" "$DISK_CRIT")
  [ "$disk_status" != "ok" ] && add_alert_inner "$disk_status" "disk" "Disco / em ${root_pct}%"

  # -- LOAD -------------------------------------------------------------------
  local load_1 load_5 load_15 n_cpus load_ratio load_status
  load_1=$(awk '{print $1}' /proc/loadavg)
  load_5=$(awk '{print $2}' /proc/loadavg)
  load_15=$(awk '{print $3}' /proc/loadavg)
  n_cpus=$(nproc)
  load_ratio=$(python3 -c "print(int($load_1 / $n_cpus * 100))")
  load_status=$(classify_inner "$load_ratio" "$((LOAD_FACTOR_WARN * 100))" "$((LOAD_FACTOR_CRIT * 100))")
  [ "$load_status" != "ok" ] && add_alert_inner "$load_status" "cpu" "Load ${load_1} em ${n_cpus} CPUs"

  # -- MEMORIA ----------------------------------------------------------------
  local mem_total mem_used mem_available mem_pct mem_status
  mem_total=$(free -m | awk '/Mem:/{print $2}')
  mem_used=$(free -m | awk '/Mem:/{print $3}')
  mem_available=$(free -m | awk '/Mem:/{print $7}')
  mem_pct=$((mem_used * 100 / mem_total))
  mem_status=$(classify_inner "$mem_pct" "$MEM_WARN" "$MEM_CRIT")
  [ "$mem_status" != "ok" ] && add_alert_inner "$mem_status" "memory" "Memoria em ${mem_pct}%"

  # -- UPTIME -----------------------------------------------------------------
  local uptime_seconds uptime_days
  uptime_seconds=$(awk '{print int($1)}' /proc/uptime)
  uptime_days=$((uptime_seconds / 86400))

  # -- SYSTEMD ----------------------------------------------------------------
  local failed_services n_failed
  failed_services="[]"
  if command -v systemctl &>/dev/null; then
    failed_services=$(systemctl --failed --no-legend --no-pager 2>/dev/null | head -10 | python3 -c "
import sys, json
s = [line.split()[0] for line in sys.stdin if line.strip()]
print(json.dumps(s))
" || echo "[]")
    n_failed=$(python3 -c "import json; print(len(json.loads('''$failed_services''')))")
    [ "$n_failed" -gt 0 ] && add_alert_inner "warning" "systemd" "$n_failed servico(s) com falha"
  fi

  # -- DOCKER -----------------------------------------------------------------
  local docker_json="null"
  if command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
    local containers stats total_log_bytes total_log_gb down

    containers=$(docker ps -a --format '{{.Names}}|{{.Status}}|{{.State}}' | python3 -c "
import sys, json
c = [{'name': p[0], 'status': p[1], 'state': p[2]} for line in sys.stdin for p in [line.strip().split('|')] if len(p)==3]
print(json.dumps(c))
")

    down=$(docker ps -a --filter "status=exited" --filter "status=dead" --format '{{.Names}}' 2>/dev/null | tr '\n' ', ' | sed 's/,$//')
    [ -n "$down" ] && add_alert_inner "critical" "docker" "Containers down: $down"

    stats=$(docker stats --no-stream --format '{{.Name}}|{{.CPUPerc}}|{{.MemUsage}}|{{.MemPerc}}' 2>/dev/null | python3 -c "
import sys, json
s = []
for line in sys.stdin:
    p = line.strip().split('|')
    if len(p)==4:
        s.append({'name':p[0].strip(),'cpu_pct':float(p[1].replace('%','').strip()),'mem_usage':p[2].strip(),'mem_pct':float(p[3].replace('%','').strip())})
print(json.dumps(s))
")

    total_log_bytes=$(find /var/lib/docker/containers -name "*-json.log" -exec du -cb {} + 2>/dev/null | tail -1 | awk '{print $1}' || echo "0")
    total_log_gb=$((total_log_bytes / 1073741824))
    [ "$total_log_gb" -ge "$LOG_SIZE_WARN_GB" ] && add_alert_inner "warning" "docker-logs" "Docker logs: ${total_log_gb}GB"

    docker_json=$(python3 -c "
import json
print(json.dumps({'containers':json.loads('''$containers'''),'stats':json.loads('''$stats'''),'log_size_gb':$total_log_gb}))
")
  fi

  # -- REDIS / SIDEKIQ --------------------------------------------------------
  local sidekiq_json="null"
  local redis_container
  redis_container=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -i redis | head -1 || true)

  local redis_cmd=""
  if [ -n "$redis_container" ]; then
    redis_cmd="docker exec $redis_container redis-cli"
  elif command -v redis-cli &>/dev/null && redis-cli ping &>/dev/null 2>&1; then
    redis_cmd="redis-cli"
  fi

  if [ -n "$redis_cmd" ]; then
    local q_total=0 queues_obj="{"
    for qname in default low high critical mailers; do
      local qlen
      qlen=$($redis_cmd llen "queue:$qname" 2>/dev/null || echo "0")
      queues_obj="$queues_obj\"$qname\":$qlen,"
      q_total=$((q_total + qlen))
    done
    queues_obj="${queues_obj}\"total\":$q_total}"
    sidekiq_json="$queues_obj"

    local q_status
    q_status=$(classify_inner "$q_total" "$QUEUE_WARN" "$QUEUE_CRIT")
    [ "$q_status" != "ok" ] && add_alert_inner "$q_status" "sidekiq" "Filas acumuladas: $q_total jobs"
  fi

  # -- POSTGRESQL -------------------------------------------------------------
  local pg_json="null"
  local pg_container
  pg_container=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -i postgres | head -1 || true)

  run_psql_inner() {
    local db="${PG_DATABASE:-}"
    [ -z "$db" ] && return 1
    if [ -n "$pg_container" ]; then
      docker exec "$pg_container" psql -U postgres -d "$db" -t -A -F'|' -c "$1" 2>/dev/null
    elif command -v psql &>/dev/null; then
      psql -U postgres -d "$db" -t -A -F'|' -c "$1" 2>/dev/null
    fi
  }

  local detected_db="${PG_DATABASE:-}"
  if [ -z "$detected_db" ]; then
    if [ -n "$pg_container" ]; then
      detected_db=$(docker exec "$pg_container" psql -U postgres -t -A -c "SELECT datname FROM pg_database WHERE datname NOT IN ('postgres','template0','template1') ORDER BY pg_database_size(datname) DESC LIMIT 1;" 2>/dev/null || true)
    elif command -v psql &>/dev/null; then
      detected_db=$(psql -U postgres -t -A -c "SELECT datname FROM pg_database WHERE datname NOT IN ('postgres','template0','template1') ORDER BY pg_database_size(datname) DESC LIMIT 1;" 2>/dev/null || true)
    fi
    PG_DATABASE="$detected_db"
  fi

  if [ -n "$PG_DATABASE" ]; then
    local pg_connections pg_tables
    pg_connections=$(run_psql_inner "SELECT count(*) FROM pg_stat_activity;" || echo "0")

    pg_tables=$(run_psql_inner "
      SELECT relname, n_dead_tup, n_live_tup,
             COALESCE(TO_CHAR(last_vacuum, 'YYYY-MM-DD HH24:MI'), 'never'),
             COALESCE(TO_CHAR(last_autovacuum, 'YYYY-MM-DD HH24:MI'), 'never')
      FROM pg_stat_user_tables
      WHERE n_dead_tup > 1000
      ORDER BY n_dead_tup DESC
      LIMIT 10;
    " || true)

    pg_json=$(echo "$pg_tables" | python3 -c "
import sys, json
tables = []
for line in sys.stdin:
    p = line.strip().split('|')
    if len(p)==5:
        tables.append({'table':p[0],'dead_tuples':int(p[1]),'live_tuples':int(p[2]),'last_vacuum':p[3],'last_autovacuum':p[4]})
print(json.dumps({'database':'$PG_DATABASE','connections':int('${pg_connections:-0}'),'tables_with_dead_tuples':tables}))
")

    local max_dead max_table dt_status
    max_dead=$(echo "$pg_tables" | awk -F'|' 'NR==1{print $2}')
    max_dead=${max_dead:-0}
    dt_status=$(classify_inner "$max_dead" "$DEAD_TUPLES_WARN" "$DEAD_TUPLES_CRIT")
    if [ "$dt_status" != "ok" ]; then
      max_table=$(echo "$pg_tables" | awk -F'|' 'NR==1{print $1}')
      add_alert_inner "$dt_status" "postgresql" "Dead tuples: $max_dead ($max_table)"
    fi
  fi

  # -- NGINX ------------------------------------------------------------------
  local nginx_json="null"
  if command -v nginx &>/dev/null; then
    local nginx_status="running"
    pgrep -x nginx &>/dev/null || nginx_status="stopped"
    nginx_json="{\"status\":\"$nginx_status\"}"
  fi

  # -- CAPABILITIES -----------------------------------------------------------
  local capabilities="[]"
  capabilities=$(python3 -c "
caps = []
import subprocess, os
def has(cmd): return subprocess.run(['which',cmd], capture_output=True).returncode == 0
def docker_ok():
    try: return subprocess.run(['docker','info'], capture_output=True).returncode == 0
    except: return False
if docker_ok(): caps.append('docker')
if has('redis-cli') or '$redis_cmd': caps.append('redis')
if '$PG_DATABASE': caps.append('postgresql')
if has('nginx'): caps.append('nginx')
if has('certbot'): caps.append('certbot')
import json; print(json.dumps(sorted(set(caps))))
" 2>/dev/null || echo "[]")

  # -- PAYLOAD ----------------------------------------------------------------
  local payload
  payload=$(python3 -c "
import json

def safe(s):
    try: return json.loads(s)
    except: return None

p = {
    'server': '$SERVER_NAME',
    'ip': '$SERVER_IP',
    'timestamp': '$timestamp',
    'status': '$overall_status',
    'mode': '$mode',
    'version': '$VERSION',
    'uptime_days': $uptime_days,
    'capabilities': json.loads('''$capabilities'''),
    'system': {
        'disk': json.loads('''$disk_json'''),
        'load_average': {'load_1m':$load_1,'load_5m':$load_5,'load_15m':$load_15,'cpus':$n_cpus},
        'memory': {'total_mb':$mem_total,'used_mb':$mem_used,'available_mb':$mem_available,'usage_pct':$mem_pct},
        'failed_services': json.loads('''$failed_services''')
    },
    'alerts': json.loads('''$alerts''')
}

for key, val in [('docker','''$docker_json'''),('sidekiq','''$sidekiq_json'''),('postgresql','''$pg_json'''),('nginx','''$nginx_json''')]:
    v = safe(val)
    if v is not None:
        p[key] = v

print(json.dumps(p, indent=2))
")

  echo "$payload"

  # Enviar
  local http_code
  http_code=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST "$WEBHOOK_URL" \
    -H "Content-Type: application/json" \
    -d "$payload" \
    --connect-timeout 10 \
    --max-time 30 \
    2>/dev/null || echo "000")

  if [ "$http_code" -ge 200 ] 2>/dev/null && [ "$http_code" -lt 300 ] 2>/dev/null; then
    ok "Enviado para webhook (HTTP $http_code)"
    log_write "OK status=$overall_status mode=$mode http=$http_code alerts=$(python3 -c "import json;print(len(json.loads('''$alerts''')))")"
    return 0
  else
    err "Falha ao enviar (HTTP $http_code)"
    log_write "ERRO status=$overall_status mode=$mode http=$http_code"
    return 1
  fi
}

# =============================================================================
# COMANDOS
# =============================================================================
cmd_run() {
  collect_and_send "report"
}

cmd_test() {
  info "Enviando report de teste..."
  echo ""
  collect_and_send "test"
}

cmd_status() {
  load_config

  echo ""
  bold "  taco status - Taco Obs v${VERSION}"
  echo -e "  ${DIM}──────────────────────────────────${NC}"
  echo -e "  Servidor:   ${BOLD}${SERVER_NAME}${NC} (${SERVER_IP})"
  echo -e "  Webhook:    ${DIM}${WEBHOOK_URL}${NC}"
  echo -e "  Intervalo:  ${BOLD}${INTERVAL_MIN} minutos${NC}"
  echo ""

  echo -e "  ${BOLD}Thresholds:${NC}"
  echo -e "    Disco:        warn=${DISK_WARN}%  crit=${DISK_CRIT}%"
  echo -e "    Memoria:      warn=${MEM_WARN}%  crit=${MEM_CRIT}%"
  echo -e "    Load factor:  warn=${LOAD_FACTOR_WARN}x  crit=${LOAD_FACTOR_CRIT}x"
  echo -e "    Sidekiq:      warn=${QUEUE_WARN}  crit=${QUEUE_CRIT}"
  echo -e "    Dead tuples:  warn=${DEAD_TUPLES_WARN}  crit=${DEAD_TUPLES_CRIT}"
  echo -e "    Docker logs:  warn=${LOG_SIZE_WARN_GB}GB"
  echo ""

  # Timer status
  if command -v systemctl &>/dev/null && systemctl is-active taco.timer &>/dev/null; then
    local next_run
    next_run=$(systemctl show taco.timer --property=NextElapseUSecRealtime --value 2>/dev/null || echo "?")
    echo -e "  ${BOLD}Timer:${NC}        ${GREEN}ativo${NC}"
    echo -e "  Proximo run:  ${next_run}"
  else
    echo -e "  ${BOLD}Timer:${NC}        ${RED}inativo${NC}"
  fi

  # Ultimo log
  if [ -f "$LOG_FILE" ]; then
    local last_log
    last_log=$(tail -1 "$LOG_FILE" 2>/dev/null || echo "nenhum")
    echo -e "  Ultimo log:   ${DIM}${last_log}${NC}"
  fi
  echo ""
}

cmd_logs() {
  if [ ! -f "$LOG_FILE" ]; then
    warn "Nenhum log encontrado."
    return
  fi
  echo ""
  bold "  taco logs - Ultimas 30 execucoes"
  echo -e "  ${DIM}──────────────────────────────────${NC}"
  tail -30 "$LOG_FILE" | while IFS= read -r line; do
    if echo "$line" | grep -q "ERRO"; then
      echo -e "  ${RED}${line}${NC}"
    elif echo "$line" | grep -q "status=critical"; then
      echo -e "  ${RED}${line}${NC}"
    elif echo "$line" | grep -q "status=warning"; then
      echo -e "  ${YELLOW}${line}${NC}"
    else
      echo -e "  ${GREEN}${line}${NC}"
    fi
  done
  echo ""
}

cmd_uninstall() {
  need_root "uninstall"

  echo ""
  echo -ne "  ${RED}Remover taco (config, timer e logs)? [s/N]${NC}: "
  read -r confirm
  if [ "${confirm,,}" != "s" ]; then
    info "Cancelado."
    return
  fi

  systemctl stop taco.timer 2>/dev/null || true
  systemctl disable taco.timer 2>/dev/null || true
  rm -f "$SYSTEMD_SERVICE" "$SYSTEMD_TIMER"
  systemctl daemon-reload 2>/dev/null || true
  rm -rf "$CONFIG_DIR" "$LOG_DIR"

  ok "Taco removido."
  echo -e "  ${DIM}O binario /usr/local/bin/taco pode ser removido manualmente.${NC}"
  echo ""
}

cmd_help() {
  echo ""
  bold "  taco - Taco Obs v${VERSION}"
  echo -e "  ${DIM}Server health check agent${NC}"
  echo ""
  echo "  Uso: taco <comando>"
  echo ""
  echo "  Comandos:"
  echo -e "    ${BOLD}install${NC}     Wizard interativo de configuracao"
  echo -e "    ${BOLD}config${NC}      Editar configuracao"
  echo -e "    ${BOLD}config set${NC}  Alterar valor direto (ex: taco config set DISK_WARN 80)"
  echo -e "    ${BOLD}run${NC}         Executa health check e envia report"
  echo -e "    ${BOLD}test${NC}        Envia report de teste para validar webhook"
  echo -e "    ${BOLD}status${NC}      Mostra configuracao e agendamento"
  echo -e "    ${BOLD}logs${NC}        Mostra ultimos logs de execucao"
  echo -e "    ${BOLD}uninstall${NC}   Remove configuracao, timer e logs"
  echo -e "    ${BOLD}help${NC}        Mostra esta ajuda"
  echo ""
}

# =============================================================================
# MAIN
# =============================================================================
case "${1:-help}" in
  install)    cmd_install ;;
  config)     cmd_config "$@" ;;
  run)        cmd_run ;;
  test)       cmd_test ;;
  status)     cmd_status ;;
  logs)       cmd_logs ;;
  uninstall)  cmd_uninstall ;;
  help|--help|-h) cmd_help ;;
  version|--version|-v) echo "taco v${VERSION}" ;;
  *)
    err "Comando desconhecido: $1"
    cmd_help
    exit 1
    ;;
esac
